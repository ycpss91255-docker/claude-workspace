{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:cafe.github.com)",
      "WebFetch(domain:productionresultssa1.blob.core.windows.net)",
      "WebFetch(domain:results-receiver.actions.githubusercontent.com)",
      "WebSearch",
      "Read",
      "Edit",
      "Write",
      "Skill(update-config)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(docker:*)",
      "Bash(make:*)",
      "Bash(./build.sh:*)",
      "Bash(./run.sh:*)",
      "Bash(./exec.sh:*)",
      "Bash(./stop.sh:*)",
      "Bash(./.base/upgrade.sh:*)",
      "Bash(./.base/init.sh:*)",
      "Bash(./script/ci.sh:*)",
      "Bash(./script/ci/ci.sh:*)",
      "Bash(./multi_run.sh:*)",
      "Bash(chmod:*)",
      "Bash(cp:*)",
      "Bash(trash-put:*)",
      "Bash(rsync:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(ssh-add:*)",
      "Bash(python3:*)",
      "Bash(tee:*)",
      "Bash(xargs:*)",
      "Bash(npm list:*)",
      "Bash(npm root:*)",
      "Bash(npm config:*)",
      "Bash(.claude/scripts/batch-template-upgrade.sh:*)",
      "Bash(.claude/scripts/batch-gitignore-fix.sh:*)",
      "Bash(.claude/scripts/batch-gitignore-add-line.sh:*)",
      "Bash(.claude/scripts/batch-pr-merge.sh:*)",
      "Bash(.claude/scripts/wait-pr-ci.sh:*)",
      "Bash(.claude/scripts/wait-tag-ci.sh:*)",
      "Bash(.claude/scripts/check-template-versions.sh:*)",
      "Bash(.claude/scripts/run-bats-in-compose.sh:*)",
      "Bash(.claude/scripts/fix-compose-copy-line.sh:*)"
    ],
    "ask": [
      "Bash(docker build:*)",
      "Bash(docker run:*)",
      "Bash(docker exec:*)",
      "Bash(docker start:*)",
      "Bash(docker stop:*)",
      "Bash(docker restart:*)",
      "Bash(docker compose:*)",
      "Bash(docker rm:*)",
      "Bash(docker rmi:*)",
      "Bash(docker kill:*)",
      "Bash(docker push:*)",
      "Bash(docker login:*)",
      "Bash(docker logout:*)",
      "Bash(docker volume rm:*)",
      "Bash(docker network rm:*)",
      "Bash(rm:*)",
      "Bash(git reset --hard:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git clean:*)",
      "Bash(git checkout --:*)",
      "Bash(git filter-branch:*)",
      "Bash(truncate:*)",
      "Bash(dd:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue reopen:*)",
      "Bash(gh pr close:*)",
      "Bash(/tmp/*.sh)",
      "Bash(bash -c:*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "docker *",
      "make *",
      "./build.sh *",
      "./run.sh *",
      "./exec.sh *",
      "./stop.sh *",
      ".claude/scripts/*"
    ],
    "filesystem": {
      "allowWrite": [
        "/tmp"
      ]
    }
  },
  "prefersReducedMotion": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto_allow_rm_in_workspace.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/auto_allow_touch_ack.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_pr_wait_ci.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_subtree_init.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_topics_yaml_on_new_repo.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_docker_for_lint.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_changelog_drift.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_readme_on_core_script.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_no_ai_attribution.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_no_heredoc_redirect.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_no_chinese_in_git_artifacts.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce_gh_body_file.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_tag_version_consistency.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce_semver_tag_via_script.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce_make_first_upgrade.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce_batch_via_script.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/enforce_worktree_for_branch.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_prefer_dot_sh.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_main_sync.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_main_fresh_before_worktree.sh",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_test_md_drift.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_no_emoji.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_no_coverage_excl.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_tdd_categories.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_test_tools_smoke_sync.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_no_ai_attribution.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_readme_framework.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_no_stale_template_refs.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_strategic_compact.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_adr_on_design_decision.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check_no_off_task_suggestions.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/remind_proactive_optimization.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
